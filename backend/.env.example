# Google OAuth — same Client ID as frontend
GOOGLE_CLIENT_ID=

# Anthropic — get at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Finnhub — free tier at https://finnhub.io/
FINNHUB_API_KEY=

# Database — SQLite locally, PostgreSQL on Railway
DATABASE_URL=sqlite:///./app.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Secrets for protected endpoints
JOB_SECRET=change-me-nightly-job-secret
ADMIN_SECRET=change-me-admin-secret

# Set to "true" to immediately trigger analysis when a ticker is added to any watchlist
AUTO_ANALYZE_ON_ADD=false

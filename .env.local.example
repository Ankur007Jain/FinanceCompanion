# Google OAuth — create at https://console.cloud.google.com/
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=

# Backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001

# E2E testing — set both to enable test sign-in bypass (never enable in production)
AUTH_TEST_MODE=
TEST_USER_EMAIL=test@financecompanion.dev
